# Git Ignore file
.idea/
launch.json

# No logs
*.log
/log

# No html
*.html

# No mac files
.DS_Store

# Limited npm runtime artifacts
node_modules/*
package-lock.json
# until an npm project skeleton is not provided for the repo, we should ignore the user-generated root package.json
/package.json

**/__pycache__/**

pkg
bin
.vscode
# Ignore local blockchain keys, node data, and environment secrets
networks/**/keys/
networks/**/data/
networks/**/grafana_db/
networks/**/grafana/provisioning/datasources/datasource.yml
*.db
*.sqlite
*.pem
*.key
.env
# Ignore network config files that contain secrets; allow example templates
networks/**/networkconfig*.json
!networks/**/networkconfig.example.json
# Ignore other local copies
**/networkconfig copy*.json